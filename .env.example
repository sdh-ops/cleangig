# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 카카오 OAuth (카카오 개발자 콘솔에서 발급)
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# 네이버 지도 API (선택)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your-naver-map-client-id

# 솔라피 알림톡 (선택)
SOLAPI_API_KEY=your-solapi-key
SOLAPI_API_SECRET=your-solapi-secret
SOLAPI_SENDER_PHONE=01012345678
SOLAPI_PF_ID=your-kakao-pf-id

# Toss Payments (선택)
TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# OpenAI (Quality Agent 사진 검수용)
OPENAI_API_KEY=your-openai-api-key

# 앱 URL (Vercel 배포 후 실제 URL로 변경)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 크론 시크릿 (자동승인 등 스케줄 API 보호 — 스케줄러는 Authorization: Bearer <값> 헤더로 호출)
CRON_SECRET=change-me-to-a-long-random-string

# 민감정보(주민등록번호) 암호화 키 — 길고 무작위한 문자열 (필수, 운영 시 변경 금지: 변경하면 기존 암호문 복호화 불가)
ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Supabase service_role 키 (서버 전용, RLS 우회 — 관리자 분쟁 처리 등에 사용. 절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
