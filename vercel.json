{
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "framework": "nextjs",
    "installCommand": "npm install",
    "outputDirectory": ".next",
    "crons": [
        {
            "path": "/api/cron/auto-approve",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cron/release-payments",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/expire-open-jobs",
            "schedule": "30 * * * *"
        }
    ]
}
